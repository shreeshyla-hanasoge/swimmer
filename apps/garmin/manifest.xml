<?xml version="1.0"?>
<!--
  SwimCoach — Connect IQ application manifest.

  Target: Garmin Instinct 2X Solar (monochrome MIP, button-only, tiny memory).
  The <iq:products> list is intentionally minimal but trivial to extend — add a
  <iq:product id="..."/> line for each new device once its UI has been checked
  against the monochrome/button-only assumptions in docs/design-rationale.md.

  // VERIFY against the installed SDK: the exact product id string for the
  // Instinct 2X Solar ("instinct2x") and the minimum API level that supports
  // JsonData resources + ActivityRecording pool-length config (>= 3.0). Run
  // `connectiq` device manager / check bin/devices.xml in your SDK.
-->
<iq:manifest xmlns:iq="http://www.garmin.com/xml/connectiq" version="3">
    <iq:application
        entry="SwimCoachApp"
        id="bafb113be4f349ccb0b3261321957893"
        launcherIcon="@Drawables.LauncherIcon"
        minApiLevel="3.2.0"
        name="@Strings.AppName"
        type="watch-app">

        <iq:products>
            <!-- Primary target -->
            <iq:product id="instinct2x"/>
            <!-- Easy to extend, e.g.:
            <iq:product id="instinct2"/>
            <iq:product id="fenix7"/>
            -->
        </iq:products>

        <iq:permissions>
            <!-- Required to record/save the swim & kick activities. -->
            <iq:uses-permission id="Fit"/>
            <!-- Sensor access for heart rate during the breathing sets. -->
            <iq:uses-permission id="Sensor"/>
            <!-- FUTURE sync (SyncClient). Declared now so wiring the backend
                 later needs no manifest change / re-review of permissions UX. -->
            <iq:uses-permission id="Communications"/>
        </iq:permissions>

        <iq:languages>
            <iq:language>eng</iq:language>
        </iq:languages>
    </iq:application>
</iq:manifest>
